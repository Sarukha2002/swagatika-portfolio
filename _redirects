# Netlify Redirects Configuration
# Swagatika Arukha Portfolio
# Place this file in the root directory of your site

# Resume download routing
/resume                         /assets/resume.pdf           200
/resume.pdf                     /assets/resume.pdf           200
/download-resume                /assets/resume.pdf           301

# Legacy route redirects
/blog                          /#writing                     301
/portfolio                     /#projects                    301
/skills                        /#stack                       301
/experience                    /#journey                     301
/contact-me                    /#contact                     301

# Prevent direct access to certain files
/sitemap.xml                   /sitemap.xml                  200
/robots.txt                     /robots.txt                   200

# Redirect staging/preview URLs to production
https://staging--*.netlify.app/* https://my-portfolio.com/:splat 301
https://deploy-preview-*.netlify.app/* https://my-portfolio.com/:splat 301

# Catch 404s and serve index.html (for single-page fallback)
/*                              /index.html                   200
