# Netlify HTTP Headers Configuration
# Swagatika Arukha Portfolio
# Place this file in the root directory of your site

# Default headers for all routes
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://fonts.googleapis.com https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://plausible.io; frame-ancestors 'self'

# Aggressive caching for versioned assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# No caching for HTML (always fresh)
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# Sitemap and robots.txt caching
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# JSON and XML files
/*.json
  Cache-Control: public, max-age=3600

# Font caching (from CDN)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
